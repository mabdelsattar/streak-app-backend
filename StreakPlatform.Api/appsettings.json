{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Database.Connection": "Information",
        "Microsoft.EntityFrameworkCore.Database.Transaction": "Information",
        "Microsoft.EntityFrameworkCore.Update": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=.\\SQLEXPRESS;Database=StreakPlatform;Trusted_Connection=True;TrustServerCertificate=True;"
    //"Default": "Server=streak-db-server.database.windows.net,1433;Initial Catalog=StreakPlatformDB;Persist Security Info=False;User ID=dbadmin;Password=P@ssw0rd@2026;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;"
  },
  "Firebase": {
    "ServiceAccountPath": "firebase-service-account.json"
  },
  "Database": {
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },
  "App": {
    //   "PublicBaseUrl": "https://polite-pond-04d28ac03.7.azurestaticapps.net",
    "PublicBaseUrl": "https://streak-app-frontend.vercel.app",
    "InvitePath": "/streaks/join",
    "MediaStorage": {
      "Provider": "Local"
    },
    "Gcs": {
      "BucketName": "",
      "ProjectId": "streakplatform",
      "CredentialsPath": "firebase-service-account.json",
      "UploadUrlTtlMinutes": 10,
      "PublicBaseUrl": "https://storage.googleapis.com"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://polite-pond-04d28ac03.7.azurestaticapps.net"
    ]
  }
}
