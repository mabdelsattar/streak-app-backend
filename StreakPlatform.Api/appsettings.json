{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Database.Connection": "Information",
        "Microsoft.EntityFrameworkCore.Database.Transaction": "Information",
        "Microsoft.EntityFrameworkCore.Update": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=.\\SQLEXPRESS;Database=StreakPlatform;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Firebase": {
    "ServiceAccountPath": "firebase-service-account.json"
  },
  "Database": {
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },
  "App": {
    "PublicBaseUrl": "http://localhost:4200",
    "InvitePath": "/streaks/join"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
